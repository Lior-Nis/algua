# Algua operator environment — copy to /etc/algua/algua.env and fill in.
# Loaded by the systemd units via EnvironmentFile=. Keep this file mode 0600 (it holds secrets).

# --- Storage --------------------------------------------------------------------------------------
# Registry/ledger SQLite DB. The per-session idempotency marker (operator_sessions.json) lives
# BESIDE it, in this file's parent directory. The run lock (operator.lock) lives at the repo's
# per-worktree git dir, not here.
ALGUA_DB_PATH=/opt/algua/data/algua.db

# Bar snapshot the paper daily-session engine runs against. Expanded into the paper unit's
# ExecStart (`… paper run-all --snapshot ${ALGUA_PAPER_SNAPSHOT}`); it is the lone variable token of
# the `paper` job's canonical argv, so it must be set for the unit to bind.
ALGUA_PAPER_SNAPSHOT=

# --- Alert hook -----------------------------------------------------------------------------------
# Optional command fed the alert JSON on stdin when a run fails / halts / hits a corrupt marker /
# a wedged lock / a calendar-out-of-bounds anomaly. It is split with shlex and run with shell=False
# under a 10s timeout — NO shell interpolation of the payload (quote args as usual; no pipes/redirects
# — wrap those in a script). Empty = log-only (the structured operator_alert record is always
# emitted). Examples:
#   ALGUA_ALERT_CMD=/usr/bin/notify-send "algua operator alert"
#   ALGUA_ALERT_CMD=curl -sS -X POST -H 'content-type: application/json' -d @- https://hooks.example/algua
ALGUA_ALERT_CMD=

# --- Alpaca PAPER credentials ---------------------------------------------------------------------
# The operator trades PAPER only. Going live is a cryptographic, human-signed wall (see the go-live
# gate) — it is NOT unlocked by supplying live creds here, so only the paper account is configured.
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_PAPER_BASE_URL=https://paper-api.alpaca.markets
